{
  "entities": {
    "leaderboard": {
      "title": "Leaderboard",
      "description": "Leaderboard scores submitted by pilots",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Pilot callsign"
        },
        "score": {
          "type": "number",
          "description": "High score achieved"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of submission"
        }
      },
      "required": ["username", "score"]
    },
    "contact_messages": {
      "title": "Contact Messages",
      "description": "Feedback and contact forms submitted by players",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Sender name",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "description": "Sender email",
          "maxLength": 150
        },
        "subject": {
          "type": "string",
          "description": "Message subject",
          "maxLength": 150
        },
        "message": {
          "type": "string",
          "description": "Message body",
          "maxLength": 1000
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of message submission"
        }
      },
      "required": ["name", "email", "subject", "message"]
    }
  },
  "firestore": {
    "leaderboard/{scoreId}": {
      "schema": "leaderboard",
      "description": "Collection of pilot high scores"
    },
    "contact_messages/{messageId}": {
      "schema": "contact_messages",
      "description": "Collection of user contact messages"
    }
  }
}
